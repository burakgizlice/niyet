node_modules
dist
dist-ssr
*.local

# Lockfile intentionally untracked: npm prunes cross-platform optional deps
# (Vite/Rolldown wasm32 -> @emnapi/*), which breaks Cloudflare's `npm ci`.
# Without it, Cloudflare runs self-healing `npm install`. See deploy notes.
package-lock.json

# Environment variables (real secrets — see .env.example)
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
