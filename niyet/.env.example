# Supabase — copy to .env and fill with your project's real values.
# Found in the Supabase dashboard under Project Settings → API.
# Both are safe to expose in the client bundle: the anon key only grants
# access permitted by Row Level Security. NEVER put the service_role key here.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>
